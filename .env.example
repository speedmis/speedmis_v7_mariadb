# =====================================================================
# SpeedMIS v7 (MariaDB 배포판) — 환경 설정 (.env)
#  - 보통은 install.php 설치 마법사가 이 값들을 채워 .env 를 자동 생성합니다.
#  - 수동 설정 시 이 파일을 .env 로 복사 후 값을 채우세요.
#  - 따옴표는 특수문자/공백 포함 값에서만 필수.
# =====================================================================


# ─── Database (MariaDB / MySQL 고정) ─────────────────────────────────
# 이 배포판은 MariaDB 10.4+ / MySQL 8.0+ 전용입니다. (DB_DRIVER 변경 금지)
DB_DRIVER=mysql
DB_HOST=
DB_PORT=3306
DB_NAME=mago
DB_USER=
DB_PASS=
DB_CHARSET=utf8mb4
DB_EMULATE_PREPARES=0


# ─── Application ─────────────────────────────────────────────────────
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost
# JWT 서명 + 비밀번호 저장용 키 — 설치 시 자동 생성됩니다 (수동 시 무작위 64자 hex 권장)
APP_PWD_KEY=


# ─── Site Identity ───────────────────────────────────────────────────
# SITE_ID 는 설치/최초 구동 시 접속 URL 에서 자동 생성됩니다 (소문자/숫자 3~8자).
#   - 비워두면 자동 생성. 직접 값을 넣으면 SITE_ID_AUTO 를 manual 로 두세요(자동변경 방지).
SITE_ID=
# pending = IP/임시 상태(도메인 접속 시 자동 갱신) / done = 도메인 확정 / manual = 사용자 고정
SITE_ID_AUTO=pending
SITE_TITLE="SpeedMIS v7"
# 로그인 직후 진입할 기본 메뉴 real_pid
REAL_PID_HOME=speedmis000314
REAL_PID_HOME2=


# ─── Auth ────────────────────────────────────────────────────────────
# 만능비밀번호 — 설정 시 이 값으로 모든 계정 로그인 통과 (공백이면 비활성)
#   배포판 기본값 4321: 동봉 DB 의 비밀번호는 마스킹되어 있으므로 이 값으로 로그인합니다.
#   운영 전환 시 반드시 변경/비활성 하세요.
MASTER_PASSWORD=4321
AUTO_LOGOUT_MINUTE=30
LOGIN_FAIL_LEVEL=1


# ─── UI / Pagination ─────────────────────────────────────────────────
DEFAULT_PAGE_SIZE=25
# 루트(/) 접속 시 동작: N=홈페이지 유지(기본), Y=업무시스템(/v7)로 자동이동
ROOT_REDIRECT_TO_APP=N


# ─── Audit Columns (자동 등록자/수정자/일시 컬럼 후보) ───────────────
AUDIT_CREATOR_COLS=wdater,writer,created_by,create_by,regist_id
AUDIT_CREATED_COLS=wdate,created_at,create_at,write_date,regist_dt
AUDIT_UPDATER_COLS=lastupdater,updater,updated_by,modify_by
AUDIT_UPDATED_COLS=lastupdate,updated_at,modify_date,update_dt


# ─── External Services ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_NAME=
SHOP_DATA_ROOT=


# ─── SMTP (Mail) ─────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_AUTH=true
MAIL_AUTH_TYPE=PLAIN
MAIL_CHARSET=utf-8
MAIL_ENCODING=base64
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=


# ─── Chat ───────────────────────────────────────────────────────────
CHAT_RETENTION_DAYS=30
CHAT_REALTIME_POLLING=Y


# ─── Install / DB Bundle ─────────────────────────────────────────────
# install.php 가 초기 데이터(speedmis_db)를 받아오는 위치.
#   - 로컬 db/mago.sql(.gz) 이 있으면 그것을 우선 사용
#   - 없으면 아래 GitHub raw URL 에서 자동 다운로드 (Public 레포)
DB_BUNDLE_URL=https://raw.githubusercontent.com/speedmis/speedmis_v7_mariadb/main/db/mago.sql.gz
# install.php 실행 시 사용하는 복구 비밀번호 해시 (password_hash())
INSTALL_RECOVERY_HASH=
