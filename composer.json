{
    "name": "speedmis/v7",
    "description": "SpeedMIS v7 - PHP 8.3 + Slim 4",
    "type": "project",
    "require": {
        "php": "^8.2",
        "slim/slim": "^4.0",
        "slim/psr7": "^1.6",
        "php-di/php-di": "^7.0",
        "vlucas/phpdotenv": "^5.5",
        "firebase/php-jwt": "^6.0",
        "monolog/monolog": "^3.0",
        "minishlink/web-push": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "core/src/"
        }
    },
    "config": {
        "optimize-autoloader": true
    },
    "audit": {
        "block-insecure": false
    }
}
